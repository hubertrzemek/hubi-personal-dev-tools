{
  "editor.mouseWheelZoom": true, // zoom Ctrl + scroll
  "editor.fontSize": 16, // rozmiar czcionki
  "editor.lineHeight": 22, // wysokość linii
  "editor.wordWrap": "on", // zawijanie długich linii

  "editor.formatOnSave": true, // formatuje automatycznie po zapisie
  "editor.formatOnPaste": true, // formatuje po wklejeniu
  "editor.formatOnType": true, // formatuje podczas pisania

  "editor.tabSize": 4, // tab = 4 spacje
  "editor.insertSpaces": true, // używa spacji zamiast tabów
  "editor.detectIndentation": false, // nie zmienia automatycznie wcięć

  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },

  "editor.suggestSelection": "first",
  "editor.parameterHints.enabled": true,
  "editor.renderWhitespace": "boundary",

  "editor.guides.bracketPairs": true,
  "editor.guides.indentation": true,

  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.minimap.enabled": false,

  "editor.codeLens": false,
  "editor.inlineSuggest.enabled": true,

  "breadcrumbs.enabled": true,

  "terminal.integrated.fontSize": 12,
  "terminal.integrated.cursorBlinking": true,

  "workbench.iconTheme": "vscode-icons",
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,

  "window.zoomLevel": 0.7,

  "files.autoSave": "afterDelay", // autozapis po czasie
  "files.autoSaveDelay": 3000, // po 3 sekundach bez pisania
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  "explorer.confirmDelete": true,

  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,

  "diffEditor.ignoreTrimWhitespace": false,

  "extensions.ignoreRecommendations": false,

  "hediet.vscode-drawio.resizeImages": null,

  "json.format.enable": true,

  "sql-formatter.uppercase": true,
  "sql-formatter.keywordCase": "upper",
  "sql-formatter.linesBetweenQueries": 2,
  "sql-formatter.tabWidth": 4,
  "sql-formatter.useTabs": false,

  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter"
  },

  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp"
  },

  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
